# Frontend env vars — copy this file to .env and fill in your values

# Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Firebase (legacy — not actively used, safe to leave blank)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Note: Edge function secrets are set via Supabase dashboard or CLI, not here.
# See README for the full list of edge function secrets needed.
